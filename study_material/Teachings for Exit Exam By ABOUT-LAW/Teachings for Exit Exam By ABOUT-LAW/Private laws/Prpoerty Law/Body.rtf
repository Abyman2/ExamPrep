\b\i\fs28\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\rtlch\fcs1 \af0\afs24 \ltrch\fcs0 \fs24\insrsid2119398\charrsid11362428 {\*\bkmkstart _Toc175128772}
\par {\*\bkmkstart _Toc194062763}{\*\bkmkstart _Toc204104808}{\*\bkmkstart _Toc229915107}8.1 DEFINITION{\*\bkmkend _Toc175128772} AND NATURE OF PUBLUIC DOMAIN}{\rtlch\fcs1 \af0\afs24 \ltrch\fcs0 \fs24\insrsid2119398 {\*\bkmkend _Toc194062763}
{\*\bkmkend _Toc204104808}{\*\bkmkend _Toc229915107}
